# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iot_billing
TIMESCALEDB_URL=postgresql://postgres:postgres@localhost:5432/iot_billing_timescale

# Redis
REDIS_URL=redis://localhost:6379

# Soroban / Stellar
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CONTRACT_ID=
ADMIN_SECRET_KEY=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
CHALLENGE_TTL_SECONDS=300

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=iot-billing-backend

# Ingestion
MAX_PAYLOAD_SIZE_BYTES=65536
NONCE_WINDOW_MS=5000

# End-to-End Encryption (issue #89)
# 64-character hex-encoded 32-byte key for payload field encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
E2E_ENCRYPTION_KEY=
