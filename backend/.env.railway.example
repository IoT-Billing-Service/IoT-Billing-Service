# Railway deployment template for iot-billing-backend
# Copy these values into your Railway service Variables tab.

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
SKIP_MIGRATION_ON_STARTUP=true
OTEL_SERVICE_NAME=iot-billing-backend

# Required infrastructure
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DB_NAME?schema=public
TIMESCALEDB_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DB_NAME?schema=public
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Soroban network configuration
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Application secrets
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ADMIN_SECRET_KEY=replace-with-a-long-random-admin-secret

# Required in production. JSON object mapping release key ids to PEM-encoded
# Ed25519 public keys. Store the matching signed envelope in Redis config:active.
RUNTIME_CONFIG_AUTHORIZED_KEYS={"billing-config-release-2026-07":"-----BEGIN PUBLIC KEY-----\\nREPLACE_ME\\n-----END PUBLIC KEY-----"}
RUNTIME_CONFIG_AUDIT_SCAN_INTERVAL_MS=1000

# Optional / deployment-specific
CONTRACT_ID=replace-with-your-deployed-contract-id
OTEL_EXPORTER_OTLP_ENDPOINT=
