generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Device {
  id        String   @id @default(cuid())
  serial    String   @unique
  publicKey String   @map("public_key")
  ownerId   String   @map("owner_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  billingRecords BillingRecord[]
  telemetryData  TelemetryData[]

  @@map("devices")
}

model Account {
  id              String   @id @default(cuid())
  stellarAddress  String   @unique @map("stellar_address")
  balance         BigInt   @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  billingRecords  BillingRecord[]
  webhookSecrets  WebhookSecret[]
  billingCycles   BillingCycle[]

  @@map("accounts")
}

model BillingRecord {
  id          String   @id @default(cuid())
  deviceId    String   @map("device_id")
  accountId   String   @map("account_id")
  usageAmount BigInt   @map("usage_amount")
  txHash      String?  @map("tx_hash")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  cycleId     String?  @map("cycle_id")

  device Device @relation(fields: [deviceId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
  cycle   BillingCycle? @relation(fields: [cycleId], references: [id])

  @@map("billing_records")
}

/// A billing cycle transitions OPEN -> FINALIZING -> FINALIZED -> SETTLED.
/// `lockVersion` is an optimistic-concurrency token: every state write does
/// `WHERE id = ? AND lock_version = ?` and bumps the version, so two callers
/// racing the same transition cannot both win (issue #42).
model BillingCycle {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  state       String   @default("OPEN")
  lockVersion Int      @default(1) @map("lock_version")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account         Account                  @relation(fields: [accountId], references: [id])
  billingRecords  BillingRecord[]
  finalizationLog BillingFinalizationLog[]

  @@index([state])
  @@map("billing_cycles")
}

/// Append-only log making finalization idempotent: a unique idempotency_key
/// means a replayed finalization for the same logical attempt is a no-op.
model BillingFinalizationLog {
  id             String   @id @default(cuid())
  cycleId        String   @map("cycle_id")
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")

  cycle BillingCycle @relation(fields: [cycleId], references: [id])

  @@map("billing_finalization_log")
}

model TelemetryData {
  id          String   @id @default(cuid())
  deviceId    String   @map("device_id")
  metricId    Int      @map("metric_id")
  metricValue Float    @map("metric_value")
  ingestedAt  DateTime @default(now()) @map("ingested_at")

  device Device @relation(fields: [deviceId], references: [id])

  @@map("telemetry_data")
}

model IngestionJob {
  id         String   @id @default(cuid())
  deviceId   String   @map("device_id")
  status     String   @default("pending")
  stateData  Json?    @map("state_data")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ingestion_jobs")
}

model WebhookSecret {
  id        String   @id @default(cuid())
  accountId String   @map("account_id")
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id])

  @@map("webhook_secrets")
}

model HardwareCertificate {
  serial    String   @id
  model     String
  batch     String
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("hardware_certificates")
}

model LedgerSyncState {
  syncId           String   @id @map("sync_id")
  lastSyncedLedger Int      @map("last_synced_ledger")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("ledger_sync_state")
}

// ---------------------------------------------------------------------------
// OAuth2 — Issue #57: Third-party billing access
// ---------------------------------------------------------------------------

/// A registered third-party application that may request delegated access to
/// the billing platform via the OAuth2 Authorization Code + PKCE flow.
/// `clientSecret` is stored as a bcrypt hash; it is never returned in API
/// responses after initial registration.
model OAuth2Client {
  id                  String   @id @default(cuid())
  /// Human-readable name shown on the consent screen.
  name                String
  /// bcrypt hash of the client secret (for confidential clients).
  /// NULL for public clients that rely solely on PKCE.
  clientSecretHash    String?  @map("client_secret_hash")
  /// Comma-separated list of allowed redirect URIs. All redirect_uri values
  /// supplied in authorisation requests must exactly match one of these.
  redirectUris        String   @map("redirect_uris")
  /// Space-separated list of OAuth2 scopes the client is allowed to request
  /// (e.g. "billing:read billing:write devices:read").
  allowedScopes       String   @map("allowed_scopes")
  /// Whether this client is still accepting new authorisation requests.
  active              Boolean  @default(true)
  /// The wallet address of the platform owner who registered this client.
  ownerWallet         String   @map("owner_wallet")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt     @map("updated_at")

  authCodes  OAuth2AuthCode[]
  tokens     OAuth2Token[]

  @@map("oauth2_clients")
}

/// A short-lived authorisation code issued at the end of the redirect step.
/// Exchanged once for an access + refresh token pair; single-use via the
/// `used` flag, enforced in the token endpoint with a DB transaction.
model OAuth2AuthCode {
  id                  String   @id @default(cuid())
  clientId            String   @map("client_id")
  /// The resource owner (Stellar wallet address) who granted consent.
  walletAddress       String   @map("wallet_address")
  /// The exact redirect_uri that was presented in the authorisation request.
  redirectUri         String   @map("redirect_uri")
  /// Space-separated scopes that were actually granted by the resource owner.
  grantedScopes       String   @map("granted_scopes")
  /// SHA-256 of the PKCE code_verifier supplied at the token endpoint.
  codeChallenge       String   @map("code_challenge")
  codeChallengeMethod String   @default("S256") @map("code_challenge_method")
  /// The opaque code value sent to the client (stored as its SHA-256 hash
  /// so plaintext never persists beyond the redirect response).
  codeHash            String   @unique @map("code_hash")
  used                Boolean  @default(false)
  expiresAt           DateTime @map("expires_at")
  createdAt           DateTime @default(now()) @map("created_at")

  client OAuth2Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([walletAddress])
  @@map("oauth2_auth_codes")
}

/// An issued OAuth2 access or refresh token.  Access tokens are short-lived
/// (configurable, default 15 min); refresh tokens are longer-lived (default
/// 30 days).  Revocation sets `revokedAt`; the token introspection endpoint
/// checks this before returning `active: true`.
///
/// `tokenHash` is the SHA-256 of the raw bearer value so the plaintext never
/// rests in the database — a compromise of the DB does not expose live tokens.
model OAuth2Token {
  id            String    @id @default(cuid())
  clientId      String    @map("client_id")
  walletAddress String    @map("wallet_address")
  /// "access" | "refresh"
  tokenType     String    @map("token_type")
  /// SHA-256 of the raw bearer string.
  tokenHash     String    @unique @map("token_hash")
  /// Space-separated scopes carried by this token.
  scopes        String
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  /// For refresh tokens, points to the access token it was issued alongside.
  parentTokenId String?     @map("parent_token_id")
  parentToken   OAuth2Token? @relation("TokenFamily", fields: [parentTokenId], references: [id])
  childTokens   OAuth2Token[] @relation("TokenFamily")

  client OAuth2Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([walletAddress])
  @@index([tokenType])
  @@map("oauth2_tokens")
}
