# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/iot_billing?schema=public
TIMESCALEDB_URL=postgresql://user:password@localhost:5432/iot_billing_timescale
REDIS_URL=redis://localhost:6379

# ── Stellar / Soroban ────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-rpc.example.com
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2021
CONTRACT_ID=
ADMIN_SECRET_KEY=your-admin-secret-key-here

# ── Authentication ────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CHALLENGE_TTL_SECONDS=300

# ── Session lifecycle / WebSocket keepalive alignment (issue #59) ────────
WS_KEEPALIVE_INTERVAL_SECONDS=60
ACCESS_TOKEN_TTL_SECONDS=1260
ACCESS_TOKEN_JITTER_SECONDS=120
TOKEN_GRACE_PERIOD_SECONDS=30
TOKEN_REFRESH_HINT_SECONDS=120

# ── Observability ────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=iot-billing-backend

# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
MAX_PAYLOAD_SIZE_BYTES=65536

# ── Ledger Synchronizer ─────────────────────────────────────────────────
LEDGER_START=0
LEDGER_SYNC_CONCURRENCY=10
SKIP_MIGRATION_ON_STARTUP=true

# ── Telemetry / TimescaleDB ──────────────────────────────────────────────
TELEMETRY_RETENTION_DAYS=365
RETENTION_SAFETY_MARGIN_DAYS=5
TELEMETRY_TARGET_CHUNK_SIZE_GB=5
TELEMETRY_COMPRESSION_DAYS=7
TELEMETRY_NUM_PARTITIONS=8

# ── Multi-region replication (issue #88) ────────────────────────────────
REGION=us-east-1
SECONDARY_REGIONS=eu-west-1,ap-southeast-1
REPLICATION_LAG_WARN_MS=5000
REPLICATION_LAG_CRITICAL_MS=30000
REPLICATION_POLL_INTERVAL_MS=10000
IS_PRIMARY_REGION=true
REPLICA_DATABASE_URL=
REPLICA_REDIS_URL=

# ── Incident Response & PagerDuty Integration (issue #85) ──────────────
PAGERDUTY_ROUTING_KEY=
PAGERDUTY_API_BASE_URL=https://events.pagerduty.com/v2
INCIDENT_DETECTION_INTERVAL_MS=30000
INCIDENT_MAX_CONCURRENT_EXECUTIONS=10